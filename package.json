{
  "name": "meetingspace",
  "version": "1.4.1",
  "description": "Windows-first desktop note-taking app for meetings with a built-in Claude layer.",
  "private": true,
  "main": "out/main/main.js",
  "author": "MeetingSpace",
  "license": "MIT",
  "comment-dependency-policy": "Runtime deps (react, react-dom, better-sqlite3) and the Electron runtime are pinned EXACT — the Electron ABI is load-bearing for the better-sqlite3 native rebuild. Dev tooling uses narrow patch-level ranges (~), EXCEPT the packaging tool electron-builder, pinned EXACT per Hard Rule §4.7 + ADR-0015 (it drives the shipped artifact). See docs/style.md 'Imports / dependencies'.",
  "comment-native-abi": "Dual-ABI: better-sqlite3 stays at Node ABI at rest (default install prebuild) so vitest (Node) and CI pass; rebuild:electron flips it to Electron's ABI for the app run path (predev/prestart). Never wire a bare postinstall electron-rebuild — it bricks the Node-ABI unit-test gate. See ADR-0003.",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "predev": "npm run rebuild:electron",
    "prestart": "npm run rebuild:electron",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "node scripts/ensure-node-abi.cjs",
    "test": "vitest run",
    "test:security": "vitest run tests/security",
    "test:integration": "vitest run tests/integration",
    "precoverage": "node scripts/ensure-node-abi.cjs",
    "coverage": "vitest run --coverage",
    "coverage:primitives": "vitest run --coverage --config vitest.primitives.config.ts",
    "audit": "npm audit --omit=dev --audit-level=high",
    "fonts:generate": "node scripts/generate-font-data.cjs",
    "e2e": "npm run rebuild:electron && npm run build && playwright test && node scripts/e2e-complete-guard.cjs",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:dir": "npm run build && electron-builder --dir --config electron-builder.yml",
    "verify:package": "node scripts/verify-package.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.100.1",
    "better-sqlite3": "12.10.0",
    "dompurify": "3.4.11",
    "parse5": "8.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "~4.0.4",
    "@eslint/js": "~9.17.0",
    "@playwright/test": "~1.60.0",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/jest-dom": "~6.9.1",
    "@testing-library/react": "~16.3.2",
    "@testing-library/user-event": "~14.6.1",
    "@types/better-sqlite3": "~7.6.13",
    "@types/node": "~22.10.0",
    "@types/react": "~18.3.0",
    "@types/react-dom": "~18.3.0",
    "@vitejs/plugin-react": "~4.3.0",
    "@vitest/coverage-v8": "~2.1.0",
    "electron": "41.7.1",
    "electron-builder": "26.8.2",
    "electron-vite": "~5.0.0",
    "eslint": "~9.17.0",
    "eslint-config-prettier": "~9.1.0",
    "eslint-plugin-react-hooks": "~5.1.0",
    "eslint-plugin-react-refresh": "~0.4.0",
    "eslint-plugin-testing-library": "~7.16.2",
    "globals": "~15.13.0",
    "husky": "~9.1.7",
    "jsdom": "~29.1.1",
    "playwright": "~1.60.0",
    "prettier": "~3.4.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "~8.18.0",
    "vite": "~5.4.0",
    "vitest": "~2.1.0"
  }
}
